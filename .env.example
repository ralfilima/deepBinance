# ============================================================
# CONFIGURAÇÃO DO BOT SCALPER - BINANCE FUTURES
# ============================================================
# Copie este arquivo para .env e configure suas credenciais

# ------------------------------------------------------------
# CREDENCIAIS DA BINANCE
# ------------------------------------------------------------
# Para TESTNET: https://testnet.binancefuture.com
# Para MAINNET: https://www.binance.com/pt-BR/futures

BINANCE_API_KEY=sua_api_key_aqui
BINANCE_SECRET_KEY=sua_secret_key_aqui

# true = Testnet (demo, sem dinheiro real)
# false = Mainnet (PRODUÇÃO, dinheiro real!)
BINANCE_TESTNET=true

# ------------------------------------------------------------
# MODO DEBUG
# ------------------------------------------------------------
# true = Ignora filtros de estratégia (para testar ordens)
# false = Usa todos os filtros da estratégia
DEBUG_MODE=false

# ------------------------------------------------------------
# GERENCIAMENTO DE RISCO
# ------------------------------------------------------------
# Porcentagem máxima do capital por posição (1.0 = 1%)
MAX_POSITION_SIZE_PERCENT=1.0

# Número máximo de posições simultâneas
MAX_OPEN_POSITIONS=5

# Perda diária máxima permitida (3.0 = 3%)
MAX_DAILY_LOSS_PERCENT=3.0

# Perdas consecutivas antes de pausar
MAX_CONSECUTIVE_LOSSES=3

# ------------------------------------------------------------
# PARÂMETROS DE ENTRADA/SAÍDA
# ------------------------------------------------------------
# Intervalo entre tentativas de entrada (segundos)
ENTRY_INTERVAL_SECONDS=600

# Jitter máximo para randomização (segundos)
JITTER_MAX_SECONDS=60

# Take Profit em % (1.05 = 1.05%)
TP_PERCENT_LONG=1.05
TP_PERCENT_SHORT=1.05

# Stop Loss em % (0.70 = 0.70%)
SL_PERCENT_LONG=0.70
SL_PERCENT_SHORT=0.70

# Time Stop em minutos
TIME_STOP_MIN=12
TIME_STOP_MAX=22

# ------------------------------------------------------------
# CONEXÃO
# ------------------------------------------------------------
API_TIMEOUT=30
MAX_RETRIES=5
RETRY_DELAY_BASE=2.0

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Níveis: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=bot.log
